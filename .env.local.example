# Verza TV — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mux (video playback)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_SIGNING_KEY_ID=your-signing-key-id
MUX_SIGNING_KEY_SECRET=your-signing-key-secret

# Stripe (payments — Phase 3)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic (AI Host / Studio — later phases)
ANTHROPIC_API_KEY=sk-ant-...

# Public
NEXT_PUBLIC_SITE_URL=https://verzatv.com
